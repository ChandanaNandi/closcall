# Copy to .env (gitignored). Secrets NEVER appear in this file (Bible §6).
# Environment variables use the CLOSCALL_ prefix; nested settings use __ (Bible §6).
CLOSCALL_ENVIRONMENT=dev
CLOSCALL_LOGGING__LEVEL=INFO
# SR Linux gNMI password for the telemetry collector. In the lab this is containerlab's documented
# default (NokiaSrl1!), not a real secret; still injected via env, never committed in YAML (§6).
SRL_PASSWORD=
