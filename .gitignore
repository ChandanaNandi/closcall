.DS_Store
.env
__pycache__/
*.pyc
.venv/

# tool caches and build output
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
dist/
*.egg-info/

# generated data never enters source folders (Bible §5)
artifacts/*
!artifacts/manifests/
!artifacts/reports/
lab/generated/*
!lab/generated/.gitkeep

# lab PKI is host secret material — NEVER committed (threat-model A2, acceptance I03)
lab/pki/*
!lab/pki/.gitkeep
